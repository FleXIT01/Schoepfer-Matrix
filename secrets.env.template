# ============================================================
#  SCHOEPFER-MATRIX - secrets.env VORLAGE
#  1) Diese Datei nach  secrets.env  kopieren
#  2) Werte eintragen
#  secrets.env ist per .gitignore geschuetzt und wird von
#  sync_secrets.py automatisch nach openclaw.json synchronisiert.
# ============================================================

# Telegram-Bot (@BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=
# Deine numerische Telegram-User-ID (@userinfobot fragen)
TELEGRAM_DEFAULT_CHAT_ID=

# OpenRouter (Cloud-Fallback DeepSeek/Claude, optional aber empfohlen)
OPENROUTER_API_KEY=

# WeKnora-RAG (nur wenn Docker-RAG-Stack genutzt wird)
WEKNORA_API_KEY=
WEKNORA_BASE_URL=http://localhost:8080
WEKNORA_KB_ID=

# OpenClaw-Gateway-Token (beliebiger langer Zufallsstring)
OPENCLAW_GATEWAY_TOKEN=

# GitHub Personal Access Token (minimal-scope, nur fuer github-MCP; optional)
GITHUB_TOKEN=

# TOTP-Secret fuer scharfe Gates (Base32; z.B. via Authenticator-App erzeugen)
TOTP_SECRET=
