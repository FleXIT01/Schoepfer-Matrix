# Bot Generator - Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.

# ============================================================
# LLM-Provider (erforderlich)
# ============================================================
# Unterstützte Werte:
#   ollama        — Lokales Ollama (kein API-Key nötig) (Standard)
#   anthropic     — Anthropic Claude API
#   openai        — OpenAI ChatGPT/GPT-4 API
#   lmstudio      — Lokales LM Studio (kein API-Key nötig)
#   openai-compat — Beliebiger OpenAI-kompatibler Endpoint
#                   (Groq, Together, vLLM, LocalAI, etc.)
LLM_PROVIDER=ollama

# LLM-Modell (optional — jeder Provider hat einen Standard)
# Beispiele:
#   Anthropic:    claude-sonnet-4-6, claude-haiku-4
#   OpenAI:       gpt-4o, gpt-4, gpt-4o-mini
#   Ollama:       llama3.1, mistral, gemma2, codellama
#   LM Studio:    (Modellname wie im LM Studio angezeigt)
LLM_MODEL=

# ============================================================
# API Keys (je nach Provider)
# ============================================================

# Anthropic API Key (erforderlich für provider=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (erforderlich für provider=openai)
OPENAI_API_KEY=sk-...

# ============================================================
# Custom Endpoint (nur für openai-compat / lmstudio / ollama)
# ============================================================
# Beispiele:
#   Ollama:       http://localhost:11434        (Standard)
#   LM Studio:    http://localhost:1234/v1      (Standard)
#   Groq:         https://api.groq.com/openai/v1
#   Together:     https://api.together.xyz/v1
#   vLLM:         http://localhost:8000/v1
LLM_API_BASE=

# ============================================================
# Ausgabe-Einstellungen
# ============================================================

# Ausgabe-Verzeichnis (optional, Standard: output)
OUTPUT_DIR=output

# Maximale Rückfragen im Interview (optional, Standard: 5)
MAX_FOLLOWUP_QUESTIONS=5
