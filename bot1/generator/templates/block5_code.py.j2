# =============================================================================
# MEMORY
# =============================================================================

class BotMemory:
    """
    Gesprächsverlauf und Zustandsverwaltung für {{ spec.name }}.
    Strategie: {{ spec.memory_strategy.value }}
    """

    def __init__(self, config: BotConfig) -> None:
        self.config = config
        self.conversation_history: list[dict[str, str]] = []
        self.state: dict[str, Any] = {}
        {% if spec.memory_strategy.value in ["persistent_json", "persistent_db"] %}
        self._storage_path = Path(
            f".{config.name.lower().replace(' ', '_')}_memory.json"
        )
        {% endif %}

    def add_message(self, role: str, content: str) -> None:
        self.conversation_history.append({"role": role, "content": content})

    def get_context_window(self, max_turns: int = 10) -> list[dict]:
        return self.conversation_history[-(max_turns * 2):]

    def set_state(self, key: str, value: Any) -> None:
        self.state[key] = value

    def get_state(self, key: str, default: Any = None) -> Any:
        return self.state.get(key, default)

    def clear(self) -> None:
        self.conversation_history.clear()
        self.state.clear()

    {% if spec.memory_strategy.value in ["persistent_json", "persistent_db"] %}
    def save(self) -> None:
        # EXTEND: Persistenz nach {{ spec.memory_strategy.value }} implementieren
        data = {"history": self.conversation_history, "state": self.state}
        self._storage_path.write_text(
            json.dumps(data, indent=2, ensure_ascii=False), encoding="utf-8"
        )

    def load(self) -> None:
        # EXTEND: Zustand beim Start laden
        if self._storage_path.exists():
            data = json.loads(self._storage_path.read_text(encoding="utf-8"))
            self.conversation_history = data.get("history", [])
            self.state = data.get("state", {})
    {% endif %}


