# =============================================================================
# BOT RUNNER
# =============================================================================

class BotRunner:
    """
    Haupt-Bot-Schleife für {{ spec.name }}.

    {{ spec.description | replace('\n', '\n    ') }}
    """

    def __init__(self, config: BotConfig | None = None) -> None:
        self.config = config or BotConfig()
        self.memory = BotMemory(self.config)
        self.tools = BotTools(self.config)
        self._client = None  # lazy-initialisiert

    def _get_client(self):
        """Erstellt den LLM-Client basierend auf dem konfigurierten Provider."""
        if self._client is None:
            {% if spec.llm.provider == "anthropic" %}
            import anthropic
            self._client = anthropic.Anthropic(
                api_key=self.config.api_key or os.environ.get("ANTHROPIC_API_KEY") or None
            )
            {% elif spec.llm.provider == "openai" %}
            import openai
            self._client = openai.OpenAI(
                api_key=self.config.api_key or os.environ.get("OPENAI_API_KEY")
            )
            {% elif spec.llm.provider == "ollama" %}
            import httpx
            self._client = httpx.Client(
                base_url=self.config.api_base_url,
                timeout=120.0,
            )
            {% else %}
            # EXTEND: Client für Provider '{{ spec.llm.provider }}' initialisieren
            import anthropic
            self._client = anthropic.Anthropic()
            {% endif %}
        return self._client

    def _build_system_prompt(self) -> str:
        return _SYSTEM_PROMPT

    def respond(self, user_message: str) -> str:
        """Verarbeite eine Nutzernachricht und gib die Bot-Antwort zurück."""
        self.memory.add_message("user", user_message)
        messages = self.memory.get_context_window()
        client = self._get_client()

        {% if spec.llm.provider == "openai" %}
        {% if spec.tools %}
        tool_defs = self.tools.get_tool_definitions()
        response = client.chat.completions.create(
            model=self.config.model,
            max_tokens=self.config.max_tokens,
            messages=[{"role": "system", "content": self._build_system_prompt()}] + messages,
            tools=[{"type": "function", "function": t} for t in tool_defs] if tool_defs else openai.NOT_GIVEN,
        )
        {% else %}
        response = client.chat.completions.create(
            model=self.config.model,
            max_tokens=self.config.max_tokens,
            messages=[{"role": "system", "content": self._build_system_prompt()}] + messages,
        )
        {% endif %}
        reply = response.choices[0].message.content or ""
        {% elif spec.llm.provider == "ollama" %}
        api_messages = [{"role": "system", "content": self._build_system_prompt()}] + list(messages)
        payload: dict = {
            "model": self.config.model,
            "messages": api_messages,
            "stream": False,
            "options": {"temperature": self.config.temperature, "num_predict": self.config.max_tokens},
        }
        {% if spec.tools %}
        # EXTEND: Ollama unterstützt Tool-Use via format="json" + manuelles Parsing
        {% endif %}
        resp = client.post("/api/chat", json=payload)
        resp.raise_for_status()
        reply = resp.json()["message"]["content"]
        {% else %}
        {% if spec.tools %}
        # EXTEND: Tool-Use Schleife für agentic Verhalten implementieren
        tool_defs = self.tools.get_tool_definitions()
        response = client.messages.create(
            model=self.config.model,
            max_tokens=self.config.max_tokens,
            system=self._build_system_prompt(),
            messages=messages,
            tools=tool_defs,
        )
        {% else %}
        response = client.messages.create(
            model=self.config.model,
            max_tokens=self.config.max_tokens,
            system=self._build_system_prompt(),
            messages=messages,
        )
        {% endif %}
        reply = response.content[0].text
        {% endif %}
        self.memory.add_message("assistant", reply)
        return reply

    def run_interactive(self) -> None:
        """Startet eine interaktive Terminal-Session."""
        print(f"Bot '{self.config.name}' gestartet. Tippe 'exit' zum Beenden.")
        print("-" * 60)

        {% if spec.memory_strategy.value in ["persistent_json", "persistent_db"] %}
        self.memory.load()
        {% endif %}

        while True:
            try:
                user_input = input("Du: ").strip()
            except (KeyboardInterrupt, EOFError):
                print("\nBot beendet.")
                break

            if user_input.lower() in ("exit", "quit", "beenden"):
                print("Bot beendet.")
                break

            if not user_input:
                continue

            # EXTEND: Pre-Processing Hooks hier einfügen
            try:
                reply = self.respond(user_input)
                print(f"\nBot: {reply}\n")
            except Exception as exc:
                print(f"\n[FEHLER] {exc}\n")
                # EXTEND: Fehlerbehandlung erweitern
            # EXTEND: Post-Processing Hooks hier einfügen

        {% if spec.memory_strategy.value in ["persistent_json", "persistent_db"] %}
        self.memory.save()
        {% endif %}


